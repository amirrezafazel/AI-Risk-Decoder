{
  "format": {
    "type": "json_schema",
    "name": "risk_analysis",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "risks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              },
              "tag": {
                "type": "string",
                "enum": [
                  "representation and toxicity",
                  "misinformation",
                  "information and safety",
                  "malicious use",
                  "human autonomy and integrity harms",
                  "socioeconomic and environmental harms"
                ]
              }
            },
            "required": ["title", "description", "severity", "tag"],
            "additionalProperties": false
          }
        }
      },
      "required": ["risks"],
      "additionalProperties": false
    }
  }
}
